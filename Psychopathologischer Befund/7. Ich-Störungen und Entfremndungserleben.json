              ]
            }
          ]
        },
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Gedankenentzug - “Andere nehmen mir meine Gedanken weg.”"
                }
              ]
            }
          ]
        },
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Gedankeneingebung - “Andere steuern meine Gedanken, geben sie ein.”"
                }
              ]
            }
          ]
        },
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Fremdbeeinflussung - “Andere beeinflussen/steuern mein Fühlen, Streben. Wollen und Handeln.” (→ paranoide Schizophrenie)"
                }
              ]
            }
          ]
        },
        {
          "type": "listItem",
