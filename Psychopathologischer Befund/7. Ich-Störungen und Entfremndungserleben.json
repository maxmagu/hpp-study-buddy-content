      ]
    },
    {
      "type": "bulletList",
      "content": [
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Gedankenausbreitung/-lautwerden - “Andere können meine Gedanken wissen/lesen/hören.”"
