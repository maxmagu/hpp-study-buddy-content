    {
      "type": "bulletList",
      "content": [
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Umgebung (Objekte, Menschen) erscheinen u.a. fremdartig, fern, unvertraut, unwillkürlich, leblos, etc."
