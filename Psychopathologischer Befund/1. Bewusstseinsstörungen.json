      "attrs": {
        "level": 2
      },
      "content": [
        {
          "type": "text",
          "text": "Bewusstsein"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        {
          "type": "text",
          "text": "Unterschiedlich definiert."
        }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        {
          "type": "text",
          "text": "Drei Bereiche nach Scharfetter"
