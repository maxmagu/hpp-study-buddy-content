      "content": [
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Vigilanz (Wachheit) als Voraussetzung des klaren Bewusstseins"
                }
              ]
            }
          ]
        },
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Bewusstseinsklarheit - Wahrnehmung und kognitive Fähigkeiten"
