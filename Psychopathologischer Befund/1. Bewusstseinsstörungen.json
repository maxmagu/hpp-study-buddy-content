        },
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Jede quantitative Bewusstseinsstörung weißt auf eine akute Gefährdung hin"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "orderedList",
