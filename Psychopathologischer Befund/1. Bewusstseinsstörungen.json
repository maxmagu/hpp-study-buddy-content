          ]
        },
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Patient reagiert nur verlangsamt, nicht situationsgerecht oder garnicht auf (lautes) Ansprechen und Anfassen"
                }
              ]
            }
          ]
        },
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Bei Fortgeschrittener Bewusstseinsstörung auch nur ungezielte oder keine Reaktion auf Schmerzreize"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "bulletList",
      "content": [
        {
          "type": "listItem",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "In der Notfallmedizin: Einteilung der Glasgow Coma Scale"
